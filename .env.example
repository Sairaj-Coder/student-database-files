# Server
PORT=3000
NODE_ENV=development

# MySQL — create database first: CREATE DATABASE student_db CHARACTER SET utf8mb4;
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=student_db

# JWT — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=8h

# Optional: comma-separated origins for CORS (leave empty to reflect request origin in dev)
CORS_ORIGIN=
